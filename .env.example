# Content storage: "local" for content-data/, "github" for the private content repository
CONTENT_STORAGE=local

# Required when CONTENT_STORAGE=github
CONTENT_GITHUB_OWNER=your-github-owner
CONTENT_GITHUB_REPO=your-content-repository
CONTENT_GITHUB_BRANCH=main
CONTENT_GITHUB_TOKEN=github-token-with-repository-content-access

# Admin authentication
ADMIN_PASSWORD=choose-a-strong-password
ADMIN_JWT_SECRET=generate-a-long-random-secret
